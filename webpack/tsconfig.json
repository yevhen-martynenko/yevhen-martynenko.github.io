{
  "compilerOptions": {
    "outDir": "static/",
    "sourceMap": true,
    "noImplicitAny": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES6",
    "jsx": "react",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": false,
    "strict": true,
    "baseUrl": ".",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./src/*"],
      "@pages/*": ["./src/pages/*"],
      "@utils/*": ["./src/utils/*"],
      "@styles/*": ["./src/styles/*"],
      "@images/*": ["./assets/images/*"],
      "@icons/*": ["./assets/images/icons/*"],
      "@fonts/*": ["./assets/fonts/*"]
    }
  },
  "ts-node": {
    "compilerOptions": {
      "module": "NodeNext"
    }
  }
}
